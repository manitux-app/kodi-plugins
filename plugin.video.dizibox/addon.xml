<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.dizibox"
       name="DiziBOX"
       version="1.0.2"
       provider-name="manitux">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.manituxhttp"/>
        <import addon="script.module.pycryptodome"/>
        <import addon="inputstream.adaptive" optional="true"/>
        <import addon="plugin.video.youtube" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" provides="video" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>DiziBOX Kodi video eklentisi</summary>
        <description>DiziBOX uzerinden dizi arsivi, bolumler ve video kaynaklarini listeler.</description>
        <platform>all</platform>
        <license>GPL-3.0-or-later</license>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
