    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="tr_TR">Kisa kod ile Kodi repository ve plugin kurucu</summary>
        <summary lang="en_GB">Kodi repository and plugin installer from short code</summary>
        <description lang="tr_TR">TinyURL gibi kisa adres servislerinden zip adresini cozer ve secime gore repository veya plugin eklentisini Kodi'ye kurar.</description>
        <description lang="en_GB">Resolves zip URLs from short URL services such as TinyURL and installs a repository or plugin add-on into Kodi.</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
<addon id="script.module.tlsclient" name="TLS Client" version="1.0.1" provider-name="serdar">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.module" library="lib"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Cross-platform TLS HTTP client module for Kodi add-ons.</summary>
        <summary lang="tr_TR">Kodi eklentileri icin platform bagimsiz TLS HTTP istemci modulu.</summary>
        <description lang="en_GB">A pure Python HTTP/TLS helper that works on Kodi platforms including Android without bundled native binaries.</description>
        <description lang="tr_TR">Android dahil Kodi platformlarinda native binary gerektirmeden calisan saf Python HTTP/TLS yardimcisi.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
<addon id="script.module.manituxhttp" name="Manitux HTTP" version="1.0.6" provider-name="manitux">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" optional="true"/>
        <import addon="script.module.beautifulsoup4" optional="true"/>
        <import addon="script.module.certifi" optional="true"/>
        <import addon="script.module.idna" optional="true"/>
        <import addon="script.module.six" optional="true"/>
        <import addon="script.module.urllib3" optional="true"/>
    </requires>
    <extension point="xbmc.python.module" library="lib"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Shared pure Python HTTP helper for Manitux Kodi add-ons.</summary>
        <summary lang="tr_TR">Manitux Kodi eklentileri icin ortak saf Python HTTP yardimcisi.</summary>
        <description lang="en_GB">Small requests-compatible HTTP wrapper with urllib fallback.</description>
        <description lang="tr_TR">Requests uyumlu, urllib yedekli kucuk HTTP sarmalayicisi.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
