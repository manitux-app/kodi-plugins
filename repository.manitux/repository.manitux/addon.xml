<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.manitux"
       name="Manitux Repository"
       version="1.0.0"
       provider-name="manitux">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Manitux Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/manitux-app/kodi-plugins/main/repository.manitux/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/manitux-app/kodi-plugins/main/repository.manitux/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/manitux-app/kodi-plugins/main/repository.manitux/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="tr_TR">Manitux Kodi eklenti deposu</summary>
        <summary lang="en_GB">Manitux Kodi add-on repository</summary>
        <description lang="tr_TR">Manitux Kodi eklentileri ve bagimliliklari icin depo.</description>
        <description lang="en_GB">Repository for Manitux Kodi add-ons and dependencies.</description>
        <platform>all</platform>
        <license>MIT</license>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
