msgctxt "#30000"
msgid "Enter short repository code or URL"
msgstr "Kisa repository kodunu veya URL'yi yazin"

msgctxt "#30001"
msgid "Resolved address does not look like a zip file:"
msgstr "Cozulen adres zip dosyasi gibi gorunmuyor:"

msgctxt "#30002"
msgid "Continue?"
msgstr "Devam edilsin mi?"

msgctxt "#30003"
msgid "Repository zip address found:"
msgstr "Repository zip adresi bulundu:"

msgctxt "#30004"
msgid "Install?"
msgstr "Kurulsun mu?"

msgctxt "#30005"
msgid "Downloading repository zip"
msgstr "Repository zip indiriliyor"

msgctxt "#30006"
msgid "Short address could not be resolved"
msgstr "Kisa adres cozulmedi"

msgctxt "#30007"
msgid "Operation cancelled"
msgstr "Islem iptal edildi"

msgctxt "#30008"
msgid "Repository installed"
msgstr "Repository kuruldu"

msgctxt "#30009"
msgid "Repository could not be installed"
msgstr "Repository kurulamadi"

msgctxt "#30010"
msgid "No add-on folder found in zip"
msgstr "Zip icinde eklenti klasoru bulunamadi"

msgctxt "#30011"
msgid "No addon.xml found in zip"
msgstr "Zip icinde addon.xml bulunamadi"

msgctxt "#30012"
msgid "Zip is not a repository add-on: {0}"
msgstr "Zip bir repository eklentisi degil: {0}"

msgctxt "#30013"
msgid "No id found in addon.xml"
msgstr "addon.xml icinde id bulunamadi"

msgctxt "#30014"
msgid "Could not read id from addon.xml"
msgstr "addon.xml icinde id okunamadi"

msgctxt "#30015"
msgid "Unsafe zip path: {0}"
msgstr "Guvenli olmayan zip yolu: {0}"

msgctxt "#30016"
msgid "Add repository"
msgstr "Repo ekle"

msgctxt "#30017"
msgid "Add plugin"
msgstr "Plugin ekle"

msgctxt "#30020"
msgid "Plugin zip address found:"
msgstr "Plugin zip adresi bulundu:"

msgctxt "#30021"
msgid "Plugin installed"
msgstr "Plugin kuruldu"

msgctxt "#30022"
msgid "Plugin could not be installed"
msgstr "Plugin kurulamadi"

msgctxt "#30023"
msgid "Zip is not a plugin add-on: {0}"
msgstr "Zip bir plugin eklentisi degil: {0}"
