<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.module.manituxhttp" name="Manitux HTTP" version="1.0.3" provider-name="manitux">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" optional="true"/>
        <import addon="script.module.beautifulsoup4" optional="true"/>
        <import addon="script.module.certifi" optional="true"/>
        <import addon="script.module.idna" optional="true"/>
        <import addon="script.module.six" optional="true"/>
        <import addon="script.module.urllib3" optional="true"/>
    </requires>
    <extension point="xbmc.python.module" library="lib"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Shared pure Python HTTP helper for Manitux Kodi add-ons.</summary>
        <summary lang="tr_TR">Manitux Kodi eklentileri icin ortak saf Python HTTP yardimcisi.</summary>
        <description lang="en_GB">Small requests-compatible HTTP wrapper with urllib fallback.</description>
        <description lang="tr_TR">Requests uyumlu, urllib yedekli kucuk HTTP sarmalayicisi.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
